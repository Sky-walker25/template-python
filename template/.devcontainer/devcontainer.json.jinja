// -*- jsonc -*-
// For format details, see https://containers.dev/implementors/json_reference/.
{
  "name": "devcontainer-{{ package_name }}",
  "build": {
    "dockerfile": "Containerfile"
  },
  // Features to add to the dev container. More info: https://containers.dev/features.
  "features": {},
  // Handle user namespace mapping
  "remoteUser": "worker",
  "containerUser": "worker",
  "updateRemoteUserUID": false,
  // Set variables during build process
  "runArgs": [
    "--name",
    "devcontainer-${localWorkspaceFolderBasename}",
    "--hostname",
    "{{ package_name }}"
  ],
  // Uncomment the next line to run commands after the container is created.
  "postCreateCommand": "just setup",
  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
          }
        }
      },
      "extensions": [
        "charliermarsh.ruff",
        "ms-python.python",
        "ms-python.black-formatter",
        "ms-python.isort",
        "ms-python.mypy-type-checker",
        "ms-python.debugpy",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-vscode.vscode-speech",
        "ms-vscode.vscode-speech-language-pack-fr-fr"
      ]
    }
  }
}
